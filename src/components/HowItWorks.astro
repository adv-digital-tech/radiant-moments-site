---
import img1 from '../assets/gallery-1.png';
import img2 from '../assets/gallery-2.png';
import img3 from '../assets/gallery-3.png';
import img4 from '../assets/gallery-4.jpg';
import img5 from '../assets/gallery-5.jpg';
import img6 from '../assets/gallery-6.jpg';
import img7 from '../assets/gallery-7.png';
const images = [
  { src: img1.src, w: 44, h: 52, top: 2, left: -2, rotate: -4, radius: 28 },
  { src: img2.src, w: 38, h: 46, top: 4, left: 46, rotate: 5, radius: 24 },
  { src: img3.src, w: 52, h: 40, top: 46, left: 4, rotate: -6, radius: 30 },
  { src: img4.src, w: 36, h: 44, top: 48, left: 56, rotate: 4, radius: 26 },
  { src: img7.src, w: 30, h: 38, top: 30, left: 28, rotate: 3, radius: 22 },
  { src: img2.src, w: 28, h: 36, top: -4, left: 82, rotate: -5, radius: 25 },
  { src: img5.src, w: 34, h: 30, top: 70, left: 38, rotate: -3, radius: 28 },
  { src: img6.src, w: 26, h: 34, top: 38, left: 70, rotate: 6, radius: 20 },
];
---

<section class="how-it-works" id="how">
  <div class="how-collage">
    {images.map((img) => (
      <div
        class="how-cell"
        style={`
          background-image: url(${img.src});
          width: ${img.w}%; height: ${img.h}%;
          top: ${img.top}%; left: ${img.left}%;
          transform: rotate(${img.rotate}deg);
          border-radius: ${img.radius}px;
        `}
      />
    ))}
  </div>
  <div class="how-fade" />
  <div class="container">
    <h2 class="section-title">Booking Is Simple</h2>
    <p class="section-sub">Three steps between now and a party everyone talks about.</p>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <h3>Tell Us About Your Event</h3>
        <p>Fill out a quick form — event type, date, location and contact information.</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h3>We Confirm the Details</h3>
        <p>We'll call or email you back to lock in your package and answer questions.</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h3>We Show Up & Set Up</h3>
        <p>Our attendant arrives early, sets up, and handles everything start to finish.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .how-it-works {
    padding: 100px 0;
    position: relative;
    overflow: hidden;
    background: var(--cream);
    background-size: cover;
    background-position: center;
    min-height: 600px;
  }
  .how-collage {
    position: absolute; inset: 0;
    z-index: 0;
    opacity: 0.2;
  }
  .how-cell {
    position: absolute;
    background-size: cover;
    background-position: center;
    filter: grayscale(0.2) contrast(1.05) brightness(0.9);
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }
  .how-fade {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, var(--cream) 0%, rgba(255,255,255,0.45) 25%, rgba(255,255,255,0.45) 75%, var(--cream) 100%);
    z-index: 1;
    pointer-events: none;
  }
  .how-it-works > .container { position: relative; z-index: 2; }
  .steps {
    display: flex; gap: 24px; margin-top: 56px;
  }
  .step { flex: 1; text-align: center; 
    background: var(--sand);
    border: 1px solid #e8e4df;
    border-radius: 16px;
    padding: 36px 28px;
    transition: transform .2s, box-shadow .2s;
  }
  .step:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,.06); }
  .step-num {
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--gold); color: var(--cream);
    font-size: 1.4rem; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
  }
  .step h3 { font-size: 1.15rem; font-weight: 700; color: var(--ink); margin-bottom: 8px; }
  .step p { color: var(--slate); font-size: 0.92rem; line-height: 1.6; }

  @media (max-width: 768px) {
    .steps { flex-direction: column; gap: 24px; }
  }
</style>
