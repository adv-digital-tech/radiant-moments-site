---
const items = [
  {
    label: "RATINGS",
    bold: "5-Star Rated",
    text: "Photo booth rentals trusted across Orange & Rockland County.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`
  },
  {
    label: "SERVICE AREA",
    bold: "Orange & Rockland County, NY",
    text: "From Middletown to Nyack, we come to you.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`
  },
  {
    label: "EVENTS",
    bold: "Every Event, Covered",
    text: "Birthday parties, weddings, graduations, church events, and corporate parties.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`
  },
  {
    label: "DELIVERY",
    bold: "Photos Delivered Instantly",
    text: "Every guest gets their photo by text or email, on the spot.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>`
  },
];
---

<section class="trust-strip">
  <div class="container">
    <div class="trust-items">
      {items.map((item, i) => (
        <div class="trust-item reveal" data-delay={i * 120}>
          <div class="trust-icon" set:html={item.icon} />
          <div class="trust-content">
            <span class="trust-label">{item.label}</span>
            <span class="trust-bold">{item.bold}</span>
            <span class="trust-text">{item.text}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-strip {
    background: var(--sand);
    padding: 32px 0;
    border-top: 1px solid #e0dcd6;
    border-bottom: 1px solid #e0dcd6;
  }
  .trust-items {
    display: flex;
    justify-content: center;
  }
  .trust-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    padding: 8px 20px;
    position: relative;
  }
  .trust-item + .trust-item {
    border-left: 1px solid #ddd8d0;
  }
  .trust-icon {
    color: var(--gold);
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .trust-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .trust-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--gold);
    text-transform: uppercase;
  }
  .trust-bold {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--ink);
  }
  .trust-text {
    font-size: 0.8rem;
    color: var(--slate);
    max-width: 220px;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .trust-items {
      flex-direction: column;
      gap: 24px;
    }
    .trust-item + .trust-item {
      border-left: none;
      padding-top: 24px;
      border-top: 1px solid #ddd8d0;
    }
    .trust-item {
      padding: 0;
    }
    .trust-text {
      max-width: 300px;
    }
  }
</style>
